---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Footer from '../../components/Footer.astro'
import { useTranslations } from '../../i18n/translations'
import { Image } from 'astro:assets'
import linkedin from '../../assets/img/linkedin.png'
import drupal from '../../assets/img/drupal.png'
import github from '../../assets/img/github.png'
import strava from '../../assets/img/strava.png'
import instagram from '../../assets/img/instagram.png'

const lang = Astro.currentLocale ?? 'de'
const t = useTranslations(lang)
---

<BaseLayout title="Lars Kleiner" lang={lang} pagePath="/">
  <div class="cards-grid">
    <a href="https://www.linkedin.com/in/larskleiner" class="card">
      <div class="card-icon-wrap" style="background: #e8f0fb;">
        <Image src={linkedin} format="webp" width={22} height={22} alt="" />
      </div>
      <div>
        <span class="card-title">LinkedIn</span>
        <span class="card-sub">{t.linkedinSub}</span>
      </div>
    </a>
    <a href="https://www.drupal.org/u/larskleiner" class="card">
      <div class="card-icon-wrap" style="background: #edf3fb;">
        <Image src={drupal} format="webp" width={22} height={22} alt="" />
      </div>
      <div>
        <span class="card-title">Drupal</span>
        <span class="card-sub">{t.drupalSub}</span>
      </div>
    </a>
    <a href="https://github.com/larskleiner" class="card">
      <div class="card-icon-wrap" style="background: #f0f0f0;">
        <Image src={github} format="webp" width={22} height={22} alt="" />
      </div>
      <div>
        <span class="card-title">GitHub</span>
        <span class="card-sub">{t.githubSub}</span>
      </div>
    </a>
    <a href="https://www.strava.com/athletes/2479560" class="card">
      <div class="card-icon-wrap" style="background: #fdeee8;">
        <Image src={strava} format="webp" width={22} height={22} alt="" />
      </div>
      <div>
        <span class="card-title">Strava</span>
        <span class="card-sub">{t.stravaSub}</span>
      </div>
    </a>
    <a href="https://www.instagram.com/larskleiner/" class="card">
      <div class="card-icon-wrap" style="background: #fce8f0;">
        <Image src={instagram} format="webp" width={22} height={22} alt="" />
      </div>
      <div>
        <span class="card-title">Instagram</span>
        <span class="card-sub">{t.instagramSub}</span>
      </div>
    </a>
  </div>
  <Footer lang={lang} />
</BaseLayout>
